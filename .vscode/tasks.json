{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Graphics Editor",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-Wall",
        "-Wextra",
        "-g3",
        "${workspaceFolder}/main.c",
        "${workspaceFolder}/graphics.c",
        "-o",
        "${workspaceFolder}/output/main.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Compile both source files for the graphics editor."
    }
  ]
}
